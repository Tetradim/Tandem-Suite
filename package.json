{
  "name": "tandem-suite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui \"tsx server/index.ts --port 8005\" \"vite --host 127.0.0.1 --port 3005\"",
    "test": "node --import tsx --test server/serverBinding.test.ts server/chromeDiscordBridge.test.ts server/relayPolicy.test.ts server/busIngressPolicy.test.ts server/windowsInstallerBootstrap.test.ts src/botLifecycle.test.ts",
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.json && vite build",
    "start": "node dist-server/server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=20"
  }
}
